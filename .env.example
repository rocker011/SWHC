# 复制为 .env 后填入真实密钥。

OPENAI_API_KEY=your_deepseek_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash
OPENAI_EMBED_MODEL=local:Qwen/Qwen3-Embedding-0.6B

HGRAG_GENERATION_BACKEND=realtime
HGRAG_GENERATION_MODEL=deepseek-v4-flash
HGRAG_GENERATION_WORKERS=2
HGRAG_OPENAI_TIMEOUT_SECONDS=180
HGRAG_RETRY_INVALID_PROMPT_WITH_PREFACE=true

HGRAG_ENABLE_LLM_JUDGE=false
HGRAG_JUDGE_BACKEND=realtime
HGRAG_JUDGE_MODEL=deepseek-v4-flash
HGRAG_SCORE_WORKERS=2

HGRAG_SWHC_SOURCE_RERANK=false
HGRAG_QUERY_CONCURRENCY=2
HGRAG_SHORTEST_ANSWER_SPAN=true

# 当前 SWHC 优化阶段默认使用 V4-Flash 非 thinking 模式。
# 现有 OpenAI-compatible 调用路径不启用 thinking / reasoning 参数。
# hotpotqa_64 优化阶段默认使用 shortest-answer-span 短输出。
